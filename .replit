modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/we-beautify-boats"

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
deploymentTarget = "static"
build = ["pnpm", "--filter", "@workspace/we-beautify-boats", "run", "build"]
publicDir = "artifacts/we-beautify-boats/dist/public"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/we-beautify-boats: web"

[[workflows.workflow]]
name = "artifacts/we-beautify-boats: web"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/we-beautify-boats run dev"
waitForPort = 5173

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["google-calendar:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
